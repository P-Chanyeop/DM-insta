# ============================================================
#  센드잇 (SendIt) — 환경변수 템플릿
#  사용법: cp .env.example .env → 실제 값으로 수정
# ============================================================

# ── DB (Lightsail Managed MySQL) ──
DB_HOST=your-lightsail-db-endpoint.ap-northeast-2.rds.amazonaws.com
DB_PORT=3306
DB_NAME=sendit
DB_USERNAME=dbmasteruser
DB_PASSWORD=your-db-password

# ── JWT (최소 256bit, HS256용) ──
JWT_SECRET=change-me-jwt-secret-key-must-be-at-least-256-bits-long

# ── Encryption (AES-256) ──
ENCRYPTION_SECRET=change-me-encryption-secret-key

# ── Instagram API ──
INSTAGRAM_APP_ID=your-instagram-app-id
INSTAGRAM_APP_SECRET=your-instagram-app-secret
INSTAGRAM_OAUTH_REDIRECT_URI=https://your-domain.com/api/auth/instagram/callback
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token

# ── Portone (Iamport) + Danal 정기결제 ──
# 가맹점 식별코드 (프론트/백 공유). 공개 값.
PORTONE_IMP_CODE=imp32683681
# REST API Key — 공개돼도 치명적이지 않으나 env 로 관리.
PORTONE_API_KEY=7884408858256314
# REST API Secret — 절대 커밋 금지. Portone 대시보드 → 식별코드·API Keys 에서 확인.
PORTONE_API_SECRET=change-me
# 채널 키(복수 PG 운영 시 사용).
PORTONE_CHANNEL_KEY=channel-key-xxxxxxxxxxxxxxxxxxxxxxxxx
# PG 상점코드. Danal PG 상점아이디(CPID).
PORTONE_PG_PROVIDER=danal_tpay
PORTONE_CPID=9810030929
# 플랜별 월 청구액(원).
PORTONE_PRICE_STARTER=19900
PORTONE_PRICE_PRO=49900
PORTONE_PRICE_BUSINESS=149900

# ── Email (Gmail SMTP) ──
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# ── App ──
APP_BASE_URL=https://your-domain.com
CORS_ALLOWED_ORIGINS=https://your-domain.com

# ── Sentry (선택) ──
SENTRY_DSN=
