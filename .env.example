# ============================================================
#  센드잇 (SendIt) — 환경변수 템플릿
#  사용법: cp .env.example .env → 실제 값으로 수정
# ============================================================

# ── DB (Lightsail Managed MySQL) ──
DB_HOST=your-lightsail-db-endpoint.ap-northeast-2.rds.amazonaws.com
DB_PORT=3306
DB_NAME=sendit
DB_USERNAME=dbmasteruser
DB_PASSWORD=your-db-password

# ── JWT (최소 256bit, HS256용) ──
JWT_SECRET=change-me-jwt-secret-key-must-be-at-least-256-bits-long

# ── Encryption (AES-256) ──
ENCRYPTION_SECRET=change-me-encryption-secret-key

# ── Instagram API ──
INSTAGRAM_APP_ID=your-instagram-app-id
INSTAGRAM_APP_SECRET=your-instagram-app-secret
INSTAGRAM_OAUTH_REDIRECT_URI=https://your-domain.com/api/auth/instagram/callback
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token

# ── 토스페이먼츠 정기결제 (빌링키) ──
# 가맹점(MID): bill_sendiomau — 자동결제(빌링) 전용 MID
# 클라이언트 키 — 프론트 SDK 초기화용. 공개돼도 무방.
TOSS_CLIENT_KEY=test_ck_4yKeq5bgrp56k0GoJ4Rx8GX0lzW6
# 시크릿 키 — REST API 인증. 절대 커밋/프론트 노출 금지.
# 토스 대시보드 → 상점관리 → 키 관리 에서 확인.
TOSS_SECRET_KEY=test_sk_kYG57Eba3GRnGEBvmlwE8pWDOxmA
# 플랜별 월 청구액(원, VAT 포함).
TOSS_PRICE_STARTER=19900
TOSS_PRICE_PRO=49900
TOSS_PRICE_BUSINESS=149900

# ── Email (Gmail SMTP) ──
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# ── App ──
APP_BASE_URL=https://your-domain.com
CORS_ALLOWED_ORIGINS=https://your-domain.com

# ── Sentry (선택) ──
SENTRY_DSN=
