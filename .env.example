# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=sendit
MYSQL_USER=sendit
MYSQL_PASSWORD=change-me-password

# JWT (최소 256bit, HS256용)
JWT_SECRET=change-me-jwt-secret-key-must-be-at-least-256-bits-long

# Instagram API
INSTAGRAM_APP_ID=your-instagram-app-id
INSTAGRAM_APP_SECRET=your-instagram-app-secret
INSTAGRAM_OAUTH_REDIRECT_URI=http://localhost:8080/api/auth/instagram/callback
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# Email (Gmail SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# App
SPRING_PROFILES_ACTIVE=prod
APP_BASE_URL=https://your-domain.com
CORS_ALLOWED_ORIGINS=https://your-domain.com

# Encryption (AES-256)
ENCRYPTION_SECRET=change-me-encryption-secret-key
