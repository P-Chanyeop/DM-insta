<Window x:Class= "SyncfusionWpfApp1.AutoComplete1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:vm="clr-namespace:SyncfusionWpfApp1.ViewModel"
        xmlns:local="clr-namespace:SyncfusionWpfApp1" xmlns:syncfusion="http://schemas.syncfusion.com/wpf" xmlns:interactivity="http://schemas.microsoft.com/xaml/behaviors"
        mc:Ignorable="d"
        Title="Softcat    게시글 작성" Height="800" Width="720">
    <Window.DataContext>
        <vm:AutoCompleteViewModel1/>
    </Window.DataContext>
    <StackPanel>
        <StackPanel Orientation="Horizontal">
            <TextBlock Text="제목" VerticalAlignment="Center" FontSize="15" FontWeight="DemiBold" Margin="30, 15, 0, 0"/>
            <syncfusion:SfTextBoxExt Width="400" Height="20" Margin="20, 15, 0, 0" VerticalAlignment="Center" Name="ARTICLE_TITLE_INPUT" Watermark="제목을 입력하세요." />
        </StackPanel>
    </StackPanel>



</Window>
