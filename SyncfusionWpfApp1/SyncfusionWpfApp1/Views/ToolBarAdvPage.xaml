<Page x:Class="SyncfusionWpfApp1.Views.ToolBarAdvPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:locals="clr-namespace:SyncfusionWpfApp1"
	  xmlns:local="clr-namespace:SyncfusionWpfApp1.ViewModels"
      xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
      xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:sync="clr-namespace:Syncfusion.Windows.Tools.Controls;assembly=Syncfusion.Tools.Wpf"
      mc:Ignorable="d"
      Title="MainPage" >
    <Grid>
        <Grid.DataContext>
            <local:ToolBarAdvViewModel/>
        </Grid.DataContext>
        <Grid.Resources>
            <ResourceDictionary>
                <ResourceDictionary.MergedDictionaries>
                    <ResourceDictionary Source="/Assets/Menu/ToolBarAdv.xaml"/>
                </ResourceDictionary.MergedDictionaries>
            </ResourceDictionary>
        </Grid.Resources>
        <Border BorderThickness="1" BorderBrush="LightGray">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Menu  Grid.ColumnSpan="1" HorizontalAlignment="Stretch" Height="25" Padding="5,3,0,-5" Background="{Binding ElementName=toolBarTray, Path=Background}">
                        <MenuItem Margin="4,0,4,0" Header="File">
                            <MenuItem
                    x:Name="newItem"
                    Command="{Binding ClickCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource Mode=Self}}"
                    Header="New"
                    InputGestureText="Ctrl+N"
                    Icon="{StaticResource New}">
                            </MenuItem>
                            <MenuItem
                    x:Name="openItem"
                    Command="{Binding ClickCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource Mode=Self}}"
                    Header="Open"
                    Icon="{StaticResource Open}">
                            </MenuItem>
                            <MenuItem
                    x:Name="saveItem"
                    Command="{Binding ClickCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource Mode=Self}}"
                    Header="Save"
                    Icon="{StaticResource Save}">
                            </MenuItem>
                            <MenuItem
                    x:Name="saveAsItem"
                    Command="{Binding ClickCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource Mode=Self}}"
                    Header="Save As" 
                    Icon="{StaticResource AdvSave}"/>
                            <MenuItem
                    x:Name="printItem"
                    Command="{Binding ClickCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource Mode=Self}}"
                    Header="Print"
                    Icon="{StaticResource Print}">
                            </MenuItem>
                            <MenuItem
                    x:Name="exitItem"
                    Command="{Binding ClickCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource Mode=Self}}"
                    Header="Exit"
                    Icon="{StaticResource Delete}"/>
                        </MenuItem>
                        <MenuItem Header="Edit" Margin="4,0,4,0">
                            <MenuItem Command="ApplicationCommands.Undo" 
                          Header="Undo"
                          Margin="4,0,4,0"
                          Icon="{StaticResource Undo}">
                            </MenuItem>
                            <MenuItem Command="ApplicationCommands.Redo" 
                          Header="Redo"
                          Margin="4,0,4,0"
                          Icon="{StaticResource Redo}">
                            </MenuItem>
                            <Separator />
                            <MenuItem
                    Command="ApplicationCommands.Cut"
                    Header="Cut"
                    InputGestureText="Ctrl+X"
                    Margin="4,0,4,0"
                    Icon="{StaticResource Cut}">
                            </MenuItem>
                            <MenuItem
                    Command="ApplicationCommands.Copy"
                    Header="Copy"
                    Margin="4,0,4,0"
                    InputGestureText="Ctrl+C"
                    Icon="{StaticResource Copy}">
                            </MenuItem>
                            <MenuItem
                    Command="ApplicationCommands.Paste"
                    Header="Paste"
                    Margin="4,0,4,0"
                    InputGestureText="Ctrl+V"
                    Icon="{StaticResource Paste}">
                            </MenuItem>
                            <MenuItem
                    x:Name="spellChecking"
                    Command="{Binding ClickCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource Mode=Self}}"
                    Header="SpellChecker"
                    Margin="4,0,4,0"
                    Icon="{StaticResource SpellChecker}">
                            </MenuItem>
                        </MenuItem>
                        <MenuItem Margin="4,0,4,0" Header="View">
                            <MenuItem
                    x:Name="findOptions"
                    Command="{Binding ClickCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource Mode=Self}}"
                    Header="Find Options">
                                <MenuItem
                        x:Name="findAllItems"
                        Command="{Binding ClickCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource Mode=Self}}"
                        Header="Find All" />
                                <MenuItem
                        x:Name="replaceAllItems"
                        Command="{Binding ClickCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource Mode=Self}}"
                        Header="Replace All" />
                            </MenuItem>
                            <MenuItem
                    x:Name="statusBarItems"
                    Command="{Binding ClickCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource Mode=Self}}"
                    Header="Status Bar"
                    InputGestureText="Alt+V" />
                        </MenuItem>
                        <MenuItem Margin="4,0,4,0" Header="Options">
                            <MenuItem Header="Can Dock At" IsCheckable="False">
                                <MenuItem
                        x:Name="canDockAtLeft"
                        Command="{Binding ClickCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource Mode=Self}}"
                        Header="Left"
                        IsCheckable="True" />
                                <MenuItem
                        x:Name="canDockAtTop"
                        Command="{Binding ClickCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource Mode=Self}}"
                        Header="Top"
                        IsCheckable="True" />
                                <MenuItem
                        x:Name="canDockAtRight"
                        Command="{Binding ClickCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource Mode=Self}}"
                        Header="Right"
                        IsCheckable="True" />
                                <MenuItem
                        x:Name="canDockAtBottom"
                        Command="{Binding ClickCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource Mode=Self}}"
                        Header="Bottom"
                        IsCheckable="True"
                        IsChecked="True" />
                            </MenuItem>
                            <MenuItem Header="Lock" IsCheckable="False">
                                <MenuItem
                        x:Name="lockLeft"
                        Command="{Binding ClickCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource Mode=Self}}"
                        Header="Left Tray"
                        IsCheckable="True" />
                                <MenuItem
                        x:Name="lockTop"
                        Command="{Binding ClickCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource Mode=Self}}"
                        Header="Top Tray"
                        IsCheckable="True" />
                                <MenuItem
                        x:Name="lockRight"
                        Command="{Binding ClickCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource Mode=Self}}"
                        Header="Right Tray"
                        IsCheckable="True" />
                                <MenuItem
                        x:Name="lockBottom"
                        Command="{Binding ClickCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource Mode=Self}}"
                        Header="Bottom Tray"
                        IsCheckable="True" />
                            </MenuItem>
                        </MenuItem>
                        <MenuItem Margin="4,0,4,0" Header="Help">
                            <MenuItem
                    x:Name="viewHelp"
                    Command="{Binding ClickCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource Mode=Self}}"
                    Header="View Help"
                    InputGestureText="F1" />
                            <MenuItem
                    x:Name="about"
                    Command="{Binding ClickCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource Mode=Self}}"
                    Header="About" />
                        </MenuItem>
                    </Menu>
                    <syncfusion:ToolBarManager
            x:Name="toolBarManager"
            Grid.Row="2"
            CanDockAtBottom="{Binding IsChecked, ElementName=canDockAtBottom}"
            CanDockAtLeft="{Binding IsChecked, ElementName=canDockAtLeft}"
            CanDockAtRight="{Binding IsChecked, ElementName=canDockAtRight}"
            CanDockAtTop="{Binding IsChecked, ElementName=canDockAtTop}">
                        <syncfusion:ToolBarManager.TopToolBarTray>
                            <syncfusion:ToolBarTrayAdv Height="32" x:Name="toolBarTray" VerticalAlignment="Top" IsLocked="{Binding Source={x:Reference lockTop},Path=IsChecked}">
                                <syncfusion:ToolBarAdv x:Name="toolBar1" GripperVisibility="Collapsed" ToolBarName="Standard" syncfusion:ToolBarManager.ToolBarState="Docking" >
                                    <Button
                            x:Name="newFile"
                            Width="22"
                            Margin="4,0,4,0"
                            Height="24"
                            syncfusion:ToolBarAdv.Label="New"
                            Command="{Binding ButtonCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource Mode=Self}}"
                            ToolTip="New" 
                            Content="{StaticResource NewFile}">
                                    </Button>
                                    <Button
                            x:Name="openFile"
                            Width="22"
                            Height="24"
                            Margin="4,0,4,0"
                            syncfusion:ToolBarAdv.Label="Open"
                            Command="{Binding ButtonCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource Mode=Self}}"
                            ToolTip="Open"
                            Content="{StaticResource OpenFile}">
                                    </Button>
                                    <Button
                            x:Name="saveFile"
                            Width="22"
                            Height="24"
                            Margin="4,0,4,0"
                            syncfusion:ToolBarAdv.Label="Save"
                            Command="{Binding ButtonCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource Mode=Self}}"
                            ToolTip="Save"
                            Content="{StaticResource SaveFile}">
                                    </Button>
                                    <Button
                            x:Name="saveAllFile"
                            Width="22"
                            Height="24"
                            Margin="4,0,4,0"
                            syncfusion:ToolBarAdv.Label="Save All"
                            Command="{Binding ButtonCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource Mode=Self}}"
                            ToolTip="SaveAll"
                            Content="{StaticResource SaveAll}">
                                    </Button>
                                    <syncfusion:ToolBarItemSeparator />
                                    <Button
                            x:Name="printFile"
                            Width="22"
                            Height="24"
                            Margin="4,0,4,0"
                            syncfusion:ToolBarAdv.Label="Print"
                            Command="{Binding ButtonCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource Mode=Self}}"
                            ToolTip="Print"
                            Content="{StaticResource PrintFile}">
                                    </Button>
                                </syncfusion:ToolBarAdv>
                                <syncfusion:ToolBarAdv x:Name="toolBar2" ToolBarName="Edit" GripperVisibility="Collapsed">
                                    <ToggleButton
                            Width="22"
                            Height="24"
                            Margin="4,0,4,0"
                            Command="EditingCommands.ToggleBold"
                            ToolTip="Bold"
                            syncfusion:ToolBarAdv.Label="Bold"
                            Content="{StaticResource Bold}">
                                    </ToggleButton>
                                    <ToggleButton
                            Width="22"
                            Height="24"
                            Margin="4,0,4,0"
                            Command="EditingCommands.ToggleItalic"
                            ToolTip="Italic"
                            syncfusion:ToolBarAdv.Label="Italic"
                            Content="{StaticResource Italics}">
                                    </ToggleButton>
                                    <ToggleButton
                            Width="22"
                            Height="24"
                            Margin="4,0,4,0"
                            Command="EditingCommands.ToggleUnderline"
                            ToolTip="Underline"
                            syncfusion:ToolBarAdv.Label="Underline"
                            Content="{StaticResource Underline}">
                                    </ToggleButton>
                                    <ToggleButton
                            Width="22"
                            Height="24"
                            Margin="4,0,4,0"
                            Command="EditingCommands.ToggleBullets"
                            ToolTip="Bullets"
                            syncfusion:ToolBarAdv.Label="Bullets"
                            Content="{StaticResource Bullets}">
                                    </ToggleButton>
                                    <ToggleButton
                            Width="22"
                            Height="24"
                            Margin="4,0,4,0"
                            Command="EditingCommands.ToggleNumbering"
                            ToolTip="Numbering"
                            syncfusion:ToolBarAdv.Label="Numbering"
                            Content="{StaticResource Numbering}">
                                    </ToggleButton>
                                    <syncfusion:ToolBarItemSeparator />
                                    <Button
                            Width="22"
                            Height="24"
                            Margin="4,0,4,0"
                            Command="EditingCommands.DecreaseIndentation"
                            ToolTip="Decrease Indent"
                            syncfusion:ToolBarAdv.Label="Decrease Indent"
                            Content="{StaticResource DecreaseIndent}">
                                    </Button>
                                    <Button
                            Width="22"
                            Height="24"
                            Margin="4,0,4,0"
                            Command="EditingCommands.IncreaseIndentation"
                            ToolTip="Increase Indent"
                            Content="{StaticResource IncreaseIndent}">
                                    </Button>
                                </syncfusion:ToolBarAdv>
                                <syncfusion:ToolBarAdv x:Name="toolBar3" ToolBarName="ClipBoard" GripperVisibility="Collapsed">
                                    <Button
                            Width="22"
                            Height="24"
                            Margin="4,0,4,0"
                            Command="ApplicationCommands.Cut"
                            ToolTip="Cut [Ctrl+X]"
                            syncfusion:ToolBarAdv.Label="Cut"
                            Content="{StaticResource CutClipboard}">
                                    </Button>
                                    <Button
                            Width="22"
                            Height="24"
                            Margin="4,0,4,0"
                            Command="ApplicationCommands.Copy"
                            ToolTip="Copy [Ctrl+C]"
                            syncfusion:ToolBarAdv.Label="Copy"
                            Content="{StaticResource CopyClipboard}">
                                    </Button>
                                    <Button
                            Width="22"
                            Height="24"
                            Margin="4,0,4,0"
                            Command="ApplicationCommands.Paste"
                            ToolTip="Paste [Ctrl+V]"
                            Content="{StaticResource PasteClipboard}">
                                    </Button>
                                </syncfusion:ToolBarAdv>
                                <syncfusion:ToolBarAdv x:Name="toolBar4" ToolBarName="Extras" GripperVisibility="Collapsed">
                                    <Button
                            x:Name="insertImage"
                            Width="22"
                            Height="24"
                            Margin="4,0,4,0"
                            Command="{Binding ButtonCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource Mode=Self}}"
                            ToolTip="Insert Images"
                            syncfusion:ToolBarAdv.Label="Insert Images"
                            Content="{StaticResource Picture}">
                                    </Button>
                                    <Button
                            x:Name="hyperLink"
                            Width="22"
                            Height="24"
                            Margin="4,0,4,0"
                            Command="{Binding ButtonCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource Mode=Self}}"
                            syncfusion:ToolBarAdv.Label="Insert Hyperlink"
                            ToolTip="Insert Hyperlink"
                            Content="{StaticResource HyperLink}">
                                    </Button>
                                    <Button
                            x:Name="table"
                            Width="22"
                            Height="24"
                            Margin="4,0,4,0"
                            Command="{Binding ButtonCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource Mode=Self}}"
                            syncfusion:ToolBarAdv.Label="Insert New Table"
                            ToolTip="Insert New Table"
                            Content="{StaticResource Tables}">
                                    </Button>
                                    <syncfusion:ToolBarItemSeparator />
                                    <Button
                            x:Name="lock"
                            Width="22"
                            Height="24"
                            Margin="4,0,4,0"
                            Command="{Binding ButtonCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource Mode=Self}}"
                            syncfusion:ToolBarAdv.Label="Read Only"
                            ToolTip="Read Only"
                            Content="{StaticResource ReadOnly}">
                                    </Button>
                                    <Button
                            x:Name="spellChecker"
                            Width="22"
                            Height="24"
                            Margin="4,0,4,0"
                            syncfusion:ToolBarAdv.Label="Spell Checker"
                            Command="{Binding ButtonCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource Mode=Self}}"
                            ToolTip="Spell Checker"
                            Content="{StaticResource SpellCheckerClipboard}">
                                    </Button>
                                </syncfusion:ToolBarAdv>
                            </syncfusion:ToolBarTrayAdv>
                        </syncfusion:ToolBarManager.TopToolBarTray>
                        <syncfusion:ToolBarManager.RightToolBarTray>
                            <syncfusion:ToolBarTrayAdv IsLocked="{Binding Source={x:Reference lockRight},Path=IsChecked}" />
                        </syncfusion:ToolBarManager.RightToolBarTray>
                        <syncfusion:ToolBarManager.BottomToolBarTray>
                            <syncfusion:ToolBarTrayAdv IsLocked="{Binding Source={x:Reference lockBottom},Path=IsChecked}" />
                        </syncfusion:ToolBarManager.BottomToolBarTray>
                    </syncfusion:ToolBarManager>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>
