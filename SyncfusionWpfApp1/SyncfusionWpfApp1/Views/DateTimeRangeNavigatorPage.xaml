<Page x:Class="SyncfusionWpfApp1.Views.DateTimeRangeNavigatorPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SyncfusionWpfApp1"
		xmlns:rangeNavigator="clr-namespace:Syncfusion.UI.Xaml.Charts;assembly=Syncfusion.SfChart.WPF"
        xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
   <Grid>
        <!--Tooltip, ZoomFactor, Zoom Position-->
        <rangeNavigator:SfDateTimeRangeNavigator ItemsSource="{Binding UsersList}" 
                                                 XBindingPath="TimeStamp"
                                                 ShowToolTip="True"
												 ZoomFactor="0.1"
												 ZoomPosition="0.3">
            <rangeNavigator:SfDateTimeRangeNavigator.DataContext>
                <local:DateTimeRangeNavigatorViewModel/>
            </rangeNavigator:SfDateTimeRangeNavigator.DataContext>
            <!--Content-->
            <rangeNavigator:SfDateTimeRangeNavigator.Content>
                <rangeNavigator:SfChart x:Name="Chart">
                    <rangeNavigator:SfChart.PrimaryAxis>
                        <rangeNavigator:DateTimeAxis IntervalType="Years" 
                                                     LabelFormat="MMM-yyyy"/>
                    </rangeNavigator:SfChart.PrimaryAxis>
                    <rangeNavigator:SfChart.SecondaryAxis>
                        <rangeNavigator:NumericalAxis Visibility="Collapsed"/>
                    </rangeNavigator:SfChart.SecondaryAxis>
                    <rangeNavigator:LineSeries ItemsSource="{Binding UsersList}" 
                                               XBindingPath="TimeStamp"
                                               YBindingPath="NoOfUsers">
                    </rangeNavigator:LineSeries>
                </rangeNavigator:SfChart>
            </rangeNavigator:SfDateTimeRangeNavigator.Content>
            <!--Interval-->
			<rangeNavigator:SfDateTimeRangeNavigator.Intervals>
                <rangeNavigator:Interval IntervalType="Year" />
            </rangeNavigator:SfDateTimeRangeNavigator.Intervals>
        </rangeNavigator:SfDateTimeRangeNavigator >
    </Grid>
</Page>
