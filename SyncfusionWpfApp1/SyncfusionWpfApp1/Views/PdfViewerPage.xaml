<Page x:Class="SyncfusionWpfApp1.Views.PdfViewerPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SyncfusionWpfApp1.ViewModels" 
		xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:syncfusion="clr-namespace:Syncfusion.Windows.PdfViewer;assembly=Syncfusion.PdfViewer.WPF"
        mc:Ignorable="d"
        Title="MainWindow" >
	<Grid>
		<Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Button Width="100"
                    Height="30"
                    Grid.Row="0"
                    Content="Export Image"
                    Click="ExportImage_Click"></Button>
        <syncfusion:PdfViewerControl Grid.Row="1"
                                     x:Name="pdfViewer"></syncfusion:PdfViewerControl>
    </Grid>
</Page>
