<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="350" d:DesignHeight="150"
		Width="350" Height="150"
        x:Class="NaverWriting.AddressInputDialog"
		WindowStartupLocation="CenterScreen"
        Title="AddressInputDialog">
	
	<StackPanel Margin="10">
		<TextBlock HorizontalAlignment="Center" Text="카페 주소를 입력하세요" Margin="0,0,0,10" />
		<TextBlock HorizontalAlignment="Center" Text="(ex. https://cafe.naver.com/joonggonara.cafe)" Margin="0, 0, 0, 10" />
		<TextBox Name="AddressTextBox" Width="250" />
		<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
			<Button HorizontalContentAlignment="Center" Content="확인" Width="60" Margin="0,0,50,0" Click="OnOkButtonClick" Background="#58FE8F" CornerRadius="12" />
			<Button HorizontalContentAlignment="Center" Content="취소" Width="60" Click="OnCancelButtonClick" CornerRadius="12" />
		</StackPanel>
	</StackPanel>
	
</Window>
