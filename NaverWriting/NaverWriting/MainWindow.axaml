<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="300"
		Width="400" Height="300"
		Background="#1E1E1E"
		Icon="/Assets/image.ico"
        x:Class="NaverWriting.MainWindow"
		WindowStartupLocation="CenterScreen"
        Title="Softcat    N사 카페 글 작성기 로그인">
	<!-- 내부 컨텐츠 설정 -->
	<StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
		<TextBlock Text="API 인증" Foreground="White" TextAlignment="Center"></TextBlock>
		<TextBox Name="api_key_input" Width="200" Height="40" Margin="0,26,0,0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Watermark="API_KEY를 입력하세요." Background="#1E1E1E" Foreground="White" BorderBrush="#727B8B" CornerRadius="8" Focusable="True" GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus"></TextBox>
		<Button Name="login_btn" Content="로그인" Width="200" Height="40" Margin="0,20,0,0" Background="#2D3239" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Foreground="White" CornerRadius="8" Click="LoginButton_Click"></Button>

	</StackPanel>
</Window>
